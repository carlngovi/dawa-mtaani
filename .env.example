# ── App identity ──────────────────────────────────────────────────────────
APP_NAME=DawaMtaani
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# For production MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=dawamtaani
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4

# ── Cache / Queue / Session ───────────────────────────────────────────────
CACHE_STORE=database
CACHE_PREFIX=
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# For production (Redis required for Horizon):
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Super admin seed credentials ─────────────────────────────────────────
# Set these before running SuperAdminSeeder. Change password on first login.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ── M-Pesa Daraja ─────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# ── I&M Bank Supply Chain Finance ─────────────────────────────────────────
# Note: formal API certification required — initiate 4+ weeks before go-live
BANK_API_URL=
BANK_API_KEY=

# ── PPB Registry ──────────────────────────────────────────────────────────
PPB_MODE=FILE
# FILE = weekly CSV upload (pilot default)
# API  = live PPB API verification (Phase 2)

# ── SGA Logistics ─────────────────────────────────────────────────────────
SGA_WEBHOOK_SECRET=

# ── WhatsApp Business API ─────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Africa's Talking (SMS fallback) ───────────────────────────────────────
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# ── Security ──────────────────────────────────────────────────────────────
# Never log, export, or commit this value. Rotate annually per spec Module 29.
ANONYMISATION_SALT=

# ── Grant reporting (locked for pilot) ───────────────────────────────────
# Do NOT modify during pilot — used for USD grant reporting only
EXCHANGE_RATE_KES_USD=127
